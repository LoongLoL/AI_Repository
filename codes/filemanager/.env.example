# .env.example - 环境变量配置模板
# 复制此文件为 .env 并修改对应的值
# WARNING: 不要提交 .env 文件到版本控制系统

# ========== Django 配置 ==========
# 生产环境必须设置为 False
DEBUG=False

# 生成强密钥：python -c 'from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())'
SECRET_KEY=your-production-secret-key-here-minimum-50-characters-long

# 允许的主机列表（逗号分隔）
ALLOWED_HOSTS=localhost,127.0.0.1,your-domain.com,www.your-domain.com

# ========== 文件管理配置 ==========
# 文件根目录（容器内路径应为 /data/files）
FILES_ROOT=/data/files

# 每页显示文件数
FILES_PER_PAGE=20

# ========== 数据库配置（可选，如果要添加数据库） ==========
# DATABASE_URL=sqlite:///db.sqlite3
# 或 PostgreSQL: postgresql://user:password@host:5432/dbname
# 或 MySQL: mysql://user:password@host:3306/dbname

# ========== Gunicorn 工作进程数 ==========
# 推荐值：CPU核心数 * 2 + 1
WORKERS=4

# ========== 日志级别 ==========
# 可选值：debug, info, warning, error, critical
LOG_LEVEL=info

# ========== 超时设置 ==========
# Gunicorn 工作进程超时（秒）
WORKER_TIMEOUT=30

# ========== HTTPS/SSL（可选） ==========
# ENABLE_SSL=true
# SSL_CERT_PATH=/etc/nginx/certs/server.crt
# SSL_KEY_PATH=/etc/nginx/certs/server.key
